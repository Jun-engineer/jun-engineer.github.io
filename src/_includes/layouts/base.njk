<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="google-site-verification" content="fUyhiNs38vI98Sfc4sU_Zuy9gXULwnl2JaKZiLsXT0I" />
  <title>{{ title | default('Jun Nammoku') }}</title>

  {%- set isJa = (lang | default('en')) == 'ja' -%}
  {%- set metaDesc = description | default(site.descriptionJa if isJa else site.description) -%}
  <meta name="description" content="{{ metaDesc }}">
  <meta name="author" content="{{ site.author.nameJa if isJa else site.author.name }}">

  {# Canonical & hreflang #}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- set slug = page.fileSlug -%}
  {%- if page.url == '/' or page.url == '/index.html' %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/portfolio/">
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/">
  {%- elif '/en/portfolio' in page.url %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/portfolio/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/portfolio/">
  {%- elif '/ja/portfolio' in page.url %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/portfolio/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/portfolio/">
  {%- elif '/en/blog/' in page.url and slug %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/blog/{{ slug }}/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/blog/{{ slug }}/">
  {%- elif '/ja/blog/' in page.url and slug %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/blog/{{ slug }}/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/blog/{{ slug }}/">
  {%- elif '/en/blog' in page.url %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/blog/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/blog/">
  {%- elif '/ja/blog' in page.url %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/blog/">
  <link rel="alternate" hreflang="ja" href="{{ site.url }}/ja/blog/">
  {%- endif %}

  {# Open Graph #}
  <meta property="og:type" content="{{ 'article' if layout == 'layouts/post.njk' else 'website' }}">
  <meta property="og:title" content="{{ title | default('Jun Nammoku') }}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="Jun Nammoku">
  <meta property="og:locale" content="{{ 'ja_JP' if isJa else 'en_AU' }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage | default(site.image) }}">

  {# Twitter Card #}
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title | default('Jun Nammoku') }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage | default(site.image) }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap">
  <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/1077/1077063.png" type="image/png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
  <link rel="stylesheet" href="/assets/css/styles.css">
  {% if extraHead %}
    {{ extraHead | safe }}
  {% endif %}

  {# JSON-LD Structured Data #}
  {%- set isJa = (lang | default('en')) == 'ja' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "name": "{{ site.author.name }}",
        "alternateName": "{{ site.author.nameJa }}",
        "jobTitle": "{{ site.author.jobTitle }}",
        "url": "{{ site.author.url }}",
        "image": "{{ site.url }}{{ site.image }}",
        "sameAs": [
          "{{ site.author.github }}",
          "{{ site.author.linkedin }}"
        ]
      },
      {
        "@type": "WebSite",
        "name": "{{ site.author.name }}",
        "alternateName": "{{ site.author.nameJa }}",
        "url": "{{ site.url }}"
      }
      {%- if layout == 'layouts/post.njk' %},
      {
        "@type": "BlogPosting",
        "headline": "{{ title }}",
        "description": "{{ description | default('') }}",
        "datePublished": "{{ page.date | date('yyyy-MM-dd') }}",
        "author": { "@type": "Person", "name": "{{ site.author.name }}" },
        "url": "{{ site.url }}{{ page.url }}",
        "inLanguage": "{{ lang | default('en') }}"
      }
      {%- endif %}
    ]
  }
  </script>
</head>
<body class="{{ bodyClass | default('') }}">
  {{ content | safe }}

  {% if extraScripts %}
    {% for script in extraScripts %}
      <script src="{{ script.src }}"{% if script.async %} async{% endif %}{% if script.defer %} defer{% endif %}></script>
    {% endfor %}
  {% endif %}
  <script src="/assets/js/main.js" defer></script>
</body>
</html>
